{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": "src",
    "baseUrl": ".",
    "paths": {
      "@game-tracker/shared": ["../../packages/shared/src"]
    },
    "types": ["bun-types"]
  },
  "include": ["src/**/*"]
}
